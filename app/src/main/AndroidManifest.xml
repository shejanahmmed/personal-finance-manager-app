<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Declare telephony hardware as optional so non-cellular devices (tablets/Wi-Fi devices) can install the app -->
    <uses-feature
        android:name="android.hardware.telephony"
        android:required="false" />

    <!-- SMS permission: used to detect incoming bank/MFS transactions in real-time on-device. -->
    <uses-permission
        android:name="android.permission.RECEIVE_SMS"
        tools:ignore="ProtectedPermissions" />
    <uses-permission
        android:name="android.permission.READ_SMS"
        tools:ignore="ProtectedPermissions" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FinanceBuddy">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.FinanceBuddy"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            SmsReceiver: intercepts incoming SMS from Bangladeshi banks and MFS.

            Security:
              - android:exported="false"  → only the system can trigger this receiver.
              - android:permission="android.permission.BROADCAST_SMS"
                → only the Android telephony system is allowed to send this broadcast.
              - Priority 999 ensures we receive the SMS before low-priority apps.
        -->
        <receiver
            android:name=".sms.SmsReceiver"
            android:exported="false"
            android:permission="android.permission.BROADCAST_SMS">
            <intent-filter android:priority="999">
                <action android:name="android.provider.Telephony.SMS_RECEIVED" />
            </intent-filter>
        </receiver>
    </application>

</manifest>